# =============================================================================
# SeeQL — Environment Variables
# =============================================================================
# Copy to .env and fill in your values.
# All variables can also be passed via docker run -e or docker-compose.yml.
# =============================================================================

# --- MySQL Production Database (required) ---
PROD_DB_HOST=10.0.0.1
PROD_DB_PORT=3306
PROD_DB_USER=dba_agent
PROD_DB_PASSWORD=your_password_here
PROD_DB_DATABASE=your_database

# --- GCP (required for Cloud Monitoring + Vertex AI) ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-south1
GCP_CLOUD_SQL_INSTANCE=your-instance-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-sa.json

# --- Size Limits ---
SEEQL_DB_MAX_SIZE_MB=5000          # Max SQLite DB size (default 5GB)
SEEQL_LOG_MAX_SIZE_MB=500          # Max total log size (default 500MB)
SEEQL_RETENTION_DAYS=90            # Data retention in days

# --- Collection Intervals (seconds) ---
SEEQL_FAST_INTERVAL=30             # Processlist, locks, transactions
SEEQL_MEDIUM_INTERVAL=300          # Query digests, wait events, InnoDB
SEEQL_SLOW_INTERVAL=1800           # Schema snapshots, index analysis

# --- LLM Agent ---
SEEQL_AGENT_ENABLED=true
SEEQL_AGENT_MODEL=gemini-2.0-flash # Or claude-sonnet-4-20250514
ANTHROPIC_API_KEY=                  # Only needed if using Claude

# --- Alerting ---
SEEQL_ALERTING_ENABLED=false
SLACK_WEBHOOK_URL=                  # Slack incoming webhook URL

# --- Prometheus ---
SEEQL_PROM_CACHE_TTL=10            # Seconds between metric refreshes

# --- General ---
SEEQL_API_PORT=8080
SEEQL_LOG_LEVEL=INFO               # DEBUG, INFO, WARNING
SEEQL_ENV=production
