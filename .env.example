# =============================================================================
# SeeQL — Secrets (environment variables)
# =============================================================================
# Copy to .env. This file holds ONLY secrets, referenced from your config file
# (seeql.yml) as ${VAR}. ALL non-secret configuration — servers/hosts,
# intervals, agent, alerting — lives in seeql.yml (copy seeql.example.yml).
# See docs/config.md.
# =============================================================================

# --- Database password(s) — referenced as ${PROD_DB_PASSWORD} in seeql.yml ---
PROD_DB_PASSWORD=your_password_here
# ANALYTICS_DB_PASSWORD=second_host_password   # if you monitor a second host

# --- LLM agent credentials (set the one matching agent.model / agent.provider) ---
# Claude via the Anthropic API:
ANTHROPIC_API_KEY=
# OpenAI (or any OpenAI-compatible endpoint — set OPENAI_BASE_URL for Azure
# OpenAI, Ollama, vLLM, Groq, OpenRouter, LM Studio, …):
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# (Gemini / Vertex-Claude use GOOGLE_APPLICATION_CREDENTIALS below.)

# --- Alerting / inbound webhooks (only if enabled in seeql.yml) ---
SLACK_WEBHOOK_URL=
SEEQL_GENERIC_WEBHOOK_SECRET=
SEEQL_GCP_WEBHOOK_SECRET=
SEEQL_PAGERDUTY_SECRET=
SEEQL_GRAFANA_SECRET=

# --- MCP server bearer token (only if you run `seeql mcp --http`) ---
SEEQL_MCP_TOKEN=

# --- GCP service-account key (only the [gcp] image / Cloud SQL metrics) ---
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-sa.json
